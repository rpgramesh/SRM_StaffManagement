rules_version = '2'
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is admin/manager
    function isAdminOrManager() {
      return request.auth != null && 
        get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.role in ['admin', 'manager'];
    }
    
    // Helper function to check if user is staff member
    function isStaffMember(staffId) {
      return request.auth != null && request.auth.uid == staffId;
    }

    // Staff collection rules
    match /staff/{staffId} {
      // Allow read access to staff documents for login flows and general lookups
      // Writes remain restricted to the staff member themselves or admins/managers
      allow read: if true;
      allow write: if isStaffMember(staffId) || isAdminOrManager();
      allow create: if isAdminOrManager() || request.auth == null; // Allow initial admin creation
      allow delete: if isAdminOrManager();
    }

    // The wildcard match below is no longer necessary for unauthenticated reads
    // but we keep it as a harmless fallback.
    match /staff/{document=**} {
      allow read: if true;
    }

    // Attendance collection rules (legacy)
    match /attendance/{attendanceId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        (isStaffMember(resource.data.staffId) || isAdminOrManager());
      allow create: if request.auth != null;
    }

    // Staff Attendance collection rules (current)
    match /staff_attendance/{attendanceId} {
      // Allow admins/managers to read all, staff can read their own records
      allow read: if request.auth != null && (
        isAdminOrManager() || (resource.data.staffId == request.auth.uid)
      );

      // Create: allow staff to create their own attendance or admins/managers
      allow create: if request.auth != null && (
        isAdminOrManager() || (request.resource.data.staffId == request.auth.uid)
      );

      // Update: allow admins/managers or the staff member who owns the record
      allow update: if request.auth != null && (
        isAdminOrManager() || (resource.data.staffId == request.auth.uid)
      );

      // Delete: only admins/managers
      allow delete: if isAdminOrManager();
    }
    
    // Schedule collection rules (legacy)
    match /schedules/{scheduleId} {
      allow read: if request.auth != null;
      allow write: if isAdminOrManager();
      allow create: if isAdminOrManager();
      allow delete: if isAdminOrManager();
    }

    // Staff Schedule collection rules (current)
    match /staff_schedule/{scheduleId} {
      // Read: allow admins/managers; staff can read only their schedules
      allow read: if request.auth != null && (
        isAdminOrManager() || (resource.data.staffId == request.auth.uid)
      );

      // Create/Update/Delete: only admins/managers
      allow create: if isAdminOrManager();
      allow update: if isAdminOrManager();
      allow delete: if isAdminOrManager();
    }
    
    // Leave requests collection rules
    match /leave_requests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if isStaffMember(resource.data.staffId) || isAdminOrManager();
      allow delete: if isAdminOrManager();
    }

    // Allow authenticated users to access their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow managers to manage orders
    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.role in ['manager', 'waiter', 'admin'];
    }

    // Allow managers to manage menu items
    match /menu/{itemId} {
      allow read: if true;
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.role in ['manager', 'admin'];
    }

    // Allow managers to manage tables
    match /tables/{tableId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.role in ['manager', 'admin', 'waiter'];
    }

    // Loyalty Points Rules
    match /loyalty_points/{pointId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow write: if false; // Only server-side operations
    }

    match /user_loyalty_data/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Only server-side operations
    }

    match /loyalty_rewards/{rewardId} {
      allow read: if request.auth != null;
      allow write: if false; // Only admin operations
    }

    // Promo Codes Rules
    match /promo_codes/{promoId} {
      allow read: if request.auth != null;
      allow write: if false; // Only admin operations
    }

    match /user_promo_usage/{usageId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow write: if false; // Only server-side operations
    }

    // Default deny
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}